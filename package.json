{
  "name": "ziwei-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "node src/cli.js examples/profile.example.json data/knowledge-snippets.example.json",
    "serve": "node src/server.js",
    "test": "node --test",
    "token:create": "node src/manageApiToken.js",
    "knowledge:draft": "node src/manageKnowledgeSnippets.js draft",
    "knowledge:draft-batch": "node src/manageKnowledgeSnippets.js draft-batch",
    "knowledge:promote": "node src/manageKnowledgeSnippets.js promote",
    "knowledge:promote-batch": "node src/manageKnowledgeSnippets.js promote-batch",
    "knowledge:append": "node src/manageKnowledgeSnippets.js append",
    "knowledge:append-batch": "node src/manageKnowledgeSnippets.js append-batch",
    "smoke:api": "node src/smokeApi.js",
    "deploy:cloudflare": "node src/deployCloudflare.js",
    "validate:cloudflare": "node src/validateCloudflare.js",
    "validate:architecture": "node src/validateAgentArchitecture.js",
    "validate:release": "node src/validateRelease.js",
    "validate:release:summary": "node src/validateRelease.js --summary .runtime/release-summary.json",
    "validate:deploy": "node src/validateDeployment.js",
    "validate:runtime": "node src/validateRuntimeConfig.js",
    "validate:knowledge": "node src/validateKnowledgeStore.js data/knowledge-snippets.example.json"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "lunar-javascript": "1.7.7"
  },
  "devDependencies": {
    "wrangler": "^4.106.0"
  }
}
