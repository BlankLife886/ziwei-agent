NODE_ENV=production
PORT=3000

# Prefer tokenHash so the server does not store plaintext bearer tokens.
# Generate a real value with: npm run token:create -- --id app-client
ZIWEI_API_CREDENTIALS=[{"id":"app-client","tokenHash":"sha256:2a98c70ddc28279197e6a78025a717b96c2313a9b50ea6587e353a258eca6dda","scopes":["reports:write"],"disabled":false}]
# Smoke checks need the plaintext token to make a real HTTP request; do not expose it in server logs.
ZIWEI_API_SMOKE_TOKEN=replace-with-secret
# Optional mounted secret/config files. Direct env vars take precedence when both are set.
# Optional managed secret command bridge. The command must be a JSON argv array and return
# a supported runtime secret JSON object, AWS SecretString, Azure value, or GCP payload.data.
# ZIWEI_MANAGED_SECRET_COMMAND=["aws","secretsmanager","get-secret-value","--secret-id","ziwei-agent/runtime","--query","SecretString","--output","text"]
# ZIWEI_MANAGED_SECRET_TIMEOUT_MS=5000
# ZIWEI_RUNTIME_SECRETS_FILE=.runtime/secrets.json
# ZIWEI_API_CREDENTIALS_FILE=/run/secrets/ziwei_api_credentials
# ZIWEI_API_TOKEN_FILE=/run/secrets/ziwei_api_token
# ZIWEI_LLM_API_KEY_FILE=/run/secrets/ziwei_llm_api_key
ZIWEI_API_OBSERVABILITY=stdout
ZIWEI_API_MAX_BODY_BYTES=100000
ZIWEI_API_RATE_LIMIT_WINDOW_MS=60000
ZIWEI_API_RATE_LIMIT_MAX=60
ZIWEI_API_QUOTA_STORE=.runtime/api-quota.json

ZIWEI_KNOWLEDGE_STORE=data/knowledge-snippets.example.json

# Optional release metadata surfaced by /health and /ready.
ZIWEI_RELEASE_VERSION=development
ZIWEI_RELEASE_COMMIT=
ZIWEI_RELEASE_SOURCE=local
ZIWEI_RELEASE_SUMMARY_PATH=.runtime/release-summary.json

# Optional external report provider.
# ZIWEI_REPORT_PROVIDER=external-llm
# ZIWEI_LLM_ENDPOINT=https://example.com/v1/chat/completions
# ZIWEI_LLM_API_KEY=replace-with-model-key
# ZIWEI_LLM_MODEL=your-model
# ZIWEI_LLM_TIMEOUT_MS=30000
# ZIWEI_LLM_RETRY_COUNT=1
# ZIWEI_LLM_MAX_RESPONSE_BYTES=200000
